# Pipeline Academy runs in local demo mode without credentials.
# Configure these only when connecting a production Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_URL=http://localhost:3000

# Provider selection. Keep demo values for a credential-free local review.
AUTH_PROVIDER=demo
DATABASE_PROVIDER=demo
EMAIL_PROVIDER=demo
GITHUB_PROVIDER=demo
PIPELINE_PROVIDER=demo
DEPLOYMENT_PROVIDER=demo
STORAGE_PROVIDER=demo
PAYMENTS_PROVIDER=demo
ANALYTICS_PROVIDER=demo
